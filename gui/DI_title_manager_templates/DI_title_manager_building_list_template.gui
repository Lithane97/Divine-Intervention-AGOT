                }

                blockoverride "buttons_destroy" {
                    DI_Title_Manager_Button_Destroy = {onclick = "[GetScriptedGui('DI_destroy_building_sgui').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).AddScope('building_type', MakeScopeFlag('the_great_wall_liaodong')).End)]"}
                }
            }
        }
    }
}
